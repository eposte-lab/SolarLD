{
  "name": "@solarlead/video-renderer",
  "version": "0.2.0",
  "private": true,
  "description": "SolarLead — sidecar that turns a before-rooftop still into a solar-panel reveal video via Replicate + ffmpeg",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@supabase/supabase-js": "^2.47.10",
    "express": "^4.21.2",
    "replicate": "^1.0.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "supertest": "^7.0.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
