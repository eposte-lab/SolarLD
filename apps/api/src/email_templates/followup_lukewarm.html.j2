{# Engagement-based follow-up — LUKEWARM scenario (score 1-20).
   Tone: light reminder, low pressure, leave-the-door-open. NEVER says
   "we noticed you opened" — uses sector_news_* hook when present, or
   a generic curiosity hook otherwise. #}
<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Una proposta veloce per {{ business_name | default('la vostra sede', true) }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f5f2eb; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Arial,sans-serif;">
<div style="display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; color:#f5f2eb;">
  Tre numeri sull'autoconsumo che possono cambiare la prospettiva.
</div>
<table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f5f2eb;">
  <tr><td align="center" style="padding:24px 12px;">
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="600" style="max-width:600px; background:#fff; border-radius:8px; overflow:hidden;">
      <tr>
        <td style="padding:20px 32px; background-color:{{ brand_primary_color | default('#0B3D2E', true) }};">
          {%- if brand_logo_url %}
          <img src="{{ brand_logo_url }}" alt="{{ tenant_name }}" width="140" style="max-height:40px; width:auto; display:block;">
          {%- else %}
          <span style="color:#fff; font-size:15px; font-weight:700;">{{ tenant_name }}</span>
          {%- endif %}
        </td>
      </tr>
      <tr>
        <td style="padding:32px 36px 28px;">
          <p style="margin:0 0 8px; font-size:12px; color:#6b6b6b; text-transform:uppercase; letter-spacing:0.5px;">
            Per {{ greeting_name }}
          </p>
          <h1 style="margin:0 0 18px; font-size:22px; line-height:28px; font-weight:700; color:#0b3d2e;">
            {{ headline | default('Tre numeri che cambiano la prospettiva', true) }}
          </h1>
          {%- if sector_news_headline %}
          <p style="margin:0 0 16px; font-size:15px; line-height:23px; color:#2b2b2b;">
            {{ sector_news_headline }}.
          </p>
          <p style="margin:0 0 20px; font-size:14px; line-height:22px; color:#444;">
            {{ sector_news_body }}
          </p>
          {%- else %}
          <p style="margin:0 0 16px; font-size:15px; line-height:23px; color:#2b2b2b;">
            {{ copy_opening_line | default('Vi scrivo per condividere tre dati semplici sull&apos;autoconsumo energetico.', true) }}
          </p>
          <p style="margin:0 0 20px; font-size:14px; line-height:22px; color:#444;">
            {{ main_copy_1 | default('Le aziende italiane simili a voi che hanno installato il fotovoltaico nell&apos;ultimo anno hanno ridotto la spesa energetica tra il 30% e il 60%, con un rientro medio di 5 anni.', true) }}
          </p>
          {%- endif %}
          {%- if roi and roi.yearly_savings_eur is defined %}
          <div style="background:#f5f2eb; border-left:4px solid {{ brand_color_accent | default('#F4A300', true) }}; padding:14px 18px; border-radius:4px; margin:0 0 22px;">
            <p style="margin:0 0 2px; font-size:11px; color:#6b6b6b; text-transform:uppercase; letter-spacing:0.6px;">La vostra stima personalizzata</p>
            <p style="margin:0; font-size:26px; line-height:32px; font-weight:700; color:#0b3d2e;">€{{ roi.yearly_savings_eur | int | format_money }}<span style="font-size:14px; font-weight:400; color:#6b6b6b;">/anno</span></p>
            {%- if roi.payback_years %}<p style="margin:4px 0 0; font-size:12px; color:#6b6b6b;">Rientro stimato: ~{{ roi.payback_years }} anni</p>{%- endif %}
          </div>
          {%- endif %}
          <table role="presentation" border="0" cellpadding="0" cellspacing="0" width="100%" style="margin:0 0 18px;">
            <tr><td align="center">
              <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                <tr><td style="background-color:{{ brand_color_accent | default('#F4A300', true) }}; border-radius:6px;">
                  <a href="{{ lead_url }}" target="_blank" style="display:inline-block; padding:14px 28px; font-size:14px; font-weight:700; color:#0b3d2e; text-decoration:none;">
                    {{ cta_primary_label | default('Vedi i dettagli', true) }} &rarr;
                  </a>
                </td></tr>
              </table>
            </td></tr>
          </table>
          <p style="margin:0; font-size:13px; line-height:20px; color:#6b6b6b;">
            {{ copy_proposition_line | default('Se invece preferite scriverci direttamente, basta rispondere a questa email.', true) }}
          </p>
        </td>
      </tr>
      <tr>
        <td style="padding:0 36px 28px; border-top:1px solid #e8e3d4;">
          <p style="margin:22px 0 4px; font-size:14px; color:#2b2b2b;">{{ sender_first_name | default(tenant_name, true) }}</p>
          <p style="margin:0; font-size:13px; color:#6b6b6b;">{{ tenant_name }}</p>
        </td>
      </tr>
      <tr>
        <td style="padding:18px 36px; background:#f5f2eb;">
          <p style="margin:0 0 6px; font-size:10px; line-height:14px; color:#888;">
            {{ tenant_legal_name | default(tenant_name, true) }}{% if tenant_vat_number %} · P.IVA {{ tenant_vat_number }}{% endif %}{% if tenant_legal_address %} · {{ tenant_legal_address }}{% endif %}
          </p>
          <p style="margin:0; font-size:10px; line-height:14px; color:#888;">
            Email B2B per legittimo interesse (art. 6.1.f GDPR). <a href="{{ optout_url }}" style="color:#888;">Annulla iscrizione</a>
          </p>
        </td>
      </tr>
    </table>
  </td></tr>
</table>
{%- if tracking_pixel_url %}<img src="{{ tracking_pixel_url }}" width="1" height="1" alt="" style="display:block;width:1px;height:1px;border:0;">{%- endif %}
</body></html>
