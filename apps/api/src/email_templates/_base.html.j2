{# ============================================================
   Shared scaffold for all SolarLead outreach emails.

   Supports three visual styles via {{ template_style }}:
     classic  – white card, 4 px brand-color accent bar (default)
     bold     – full-width gradient hero header, dark ROI box
     minimal  – editorial whitespace, brand-underlined H1, no card

   CSS is inlined via `premailer` before sending so every rule
   survives Gmail / Outlook / Apple Mail.

   Context variables (new, optional):
     template_style   str   classic | bold | minimal   default: classic
     headline         str   AI-generated H1 override
     main_copy_1      str   First body paragraph override
     main_copy_2      str   Second body paragraph override
     cta_text         str   CTA button label override
     brand_logo_url   str   Absolute URL to tenant logo
   ============================================================ #}
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{{ subject }}</title>
    <style>
      /* ---- reset ---- */
      body { margin:0; padding:0; -webkit-text-size-adjust:100%; }
      img  { border:0; display:block; }
      a    { text-decoration:none; }

      {% if template_style == 'bold' %}
      /* ============================================================
         BOLD  – gradient hero header, dark ROI panel
         ============================================================ */
      body {
        background: #111827;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        color: #f9fafb;
      }
      .wrap   { max-width:600px; margin:0 auto; padding:24px 16px; }
      .card   { background:#fff; border-radius:16px; overflow:hidden; }

      /* gradient hero */
      .hero-header {
        background: {{ brand_primary_color }};
        padding: 36px 32px 28px;
      }
      .hero-header .logo-img { height:32px; width:auto; margin-bottom:18px; opacity:.9; }
      .hero-header .big-h1  {
        font-size:26px; font-weight:800; color:#fff;
        margin:0; line-height:1.22; letter-spacing:-.02em;
      }
      .hero-header .sub-h1  { font-size:14px; color:rgba(255,255,255,.78); margin-top:6px; }

      /* hero image */
      .hero-img img { width:100%; height:auto; }

      /* content area */
      .content { padding:28px 32px 24px; background:#fff; color:#0f172a; }
      /* hide the child-template <h1> — headline is in .hero-header */
      .content h1 { display:none !important; }
      h1 { display:none !important; }
      p  { margin:0 0 14px 0; font-size:15px; color:#374151; }

      /* ROI box — dark */
      .roi {
        background:#111827; border-radius:10px;
        padding:18px 22px; margin:20px 0;
      }
      .roi-row   { display:flex; justify-content:space-between; margin:6px 0; }
      .roi-label { color:#9ca3af; font-size:13px; }
      .roi-value { color:#f9fafb; font-weight:700; font-size:14px; }

      /* CTA — pill */
      .cta {
        display:inline-block;
        background:{{ brand_primary_color }}; color:#fff !important;
        font-weight:800; font-size:13px; letter-spacing:.05em; text-transform:uppercase;
        padding:13px 30px; border-radius:50px; margin-top:10px;
      }
      .sign   { color:#6b7280; font-size:13px; margin-top:22px; }
      .footer { font-size:12px; color:#6b7280; text-align:center; margin-top:20px; }
      .footer a { color:#6b7280; text-decoration:underline; }

      {% elif template_style == 'minimal' %}
      /* ============================================================
         MINIMAL  – editorial whitespace, Georgia body, accent underline
         ============================================================ */
      body {
        background:#fff;
        font-family: Georgia, "Times New Roman", "DejaVu Serif", serif;
        color:#1a1a1a;
      }
      .wrap { max-width:560px; margin:0 auto; padding:48px 24px; }
      .card { background:transparent; }

      /* thin branded top rule */
      .minimal-header {
        border-bottom:3px solid {{ brand_primary_color }};
        padding-bottom:14px; margin-bottom:32px;
      }
      .minimal-header .logo-img { height:28px; width:auto; }
      .minimal-header .brand-name {
        font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;
        font-size:12px; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
        color:{{ brand_primary_color }};
      }

      /* hero image */
      .hero-img img { width:100%; height:auto; margin-bottom:28px; border-radius:4px; }

      /* content area */
      .content { background:transparent; }
      h1 {
        font-size:28px; font-weight:700; margin:0 0 22px 0;
        color:#1a1a1a; line-height:1.22;
      }
      p  { margin:0 0 18px 0; font-size:16px; color:#333; line-height:1.72; }

      /* ROI — left accent bar */
      .roi {
        border-left:3px solid {{ brand_primary_color }};
        background:#f7f7f7; padding:16px 20px; margin:24px 0;
      }
      .roi-row   { display:flex; justify-content:space-between; margin:5px 0; }
      .roi-label { color:#666; font-size:13px; font-family:-apple-system,Arial,sans-serif; }
      .roi-value { color:#1a1a1a; font-weight:700; font-size:14px; font-family:-apple-system,Arial,sans-serif; }

      /* CTA — underline link style */
      .cta {
        display:inline-block; color:{{ brand_primary_color }} !important;
        font-weight:700; font-size:15px; border-bottom:2px solid {{ brand_primary_color }};
        padding-bottom:2px; margin-top:8px;
        font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Arial,sans-serif;
      }
      .sign   { color:#888; font-size:13px; margin-top:32px; font-family:-apple-system,Arial,sans-serif; }
      .footer {
        font-size:11px; color:#aaa; margin-top:40px;
        padding-top:20px; border-top:1px solid #eee;
        font-family:-apple-system,Arial,sans-serif;
      }
      .footer a { color:#aaa; text-decoration:underline; }

      {% else %}
      /* ============================================================
         CLASSIC (default)  – white card, accent bar, solid CTA
         ============================================================ */
      body {
        background:#f1f5f9;
        font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"Helvetica Neue",Arial,sans-serif;
        color:#0f172a;
      }
      .wrap { max-width:600px; margin:0 auto; padding:28px 16px; }
      .card { background:#fff; border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; }

      /* accent bar */
      .accent-bar { height:5px; background:{{ brand_primary_color }}; }

      /* logo row */
      .logo-row { padding:20px 28px 0; }
      .logo-row .logo-img { height:36px; width:auto; }

      /* hero image */
      .hero-img img { width:100%; height:auto; }

      /* content area */
      .content { padding:28px 28px 24px; }
      h1 { font-size:22px; font-weight:700; margin:0 0 14px 0; color:#0f172a; line-height:1.3; }
      p  { margin:0 0 14px 0; font-size:15px; color:#334155; }

      /* ROI box — light */
      .roi {
        background:#f8fafc; border:1px solid #e2e8f0;
        border-radius:10px; padding:18px 20px; margin:18px 0;
      }
      .roi-row   { display:flex; justify-content:space-between; margin:5px 0; }
      .roi-label { color:#64748b; font-size:13px; }
      .roi-value { color:#0f172a; font-weight:700; font-size:14px; }

      /* CTA — solid rounded */
      .cta {
        display:inline-block;
        background:{{ brand_primary_color }}; color:#fff !important;
        font-weight:700; font-size:15px; padding:13px 26px;
        border-radius:9px; margin-top:10px; letter-spacing:.01em;
      }
      .sign   { color:#64748b; font-size:13px; margin-top:22px; }
      .footer { font-size:12px; color:#94a3b8; text-align:center; margin-top:20px; }
      .footer a { color:#94a3b8; text-decoration:underline; }
      {% endif %}
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">

        {# -------- BOLD: gradient hero header -------- #}
        {% if template_style == 'bold' %}
          <div class="hero-header">
            {% if brand_logo_url %}
              <img class="logo-img" src="{{ brand_logo_url }}" alt="{{ tenant_name }}" />
            {% endif %}
            <div class="big-h1">
              {{ headline or 'La tua simulazione fotovoltaica è pronta' }}
            </div>
          </div>

        {# -------- MINIMAL: thin top rule -------- #}
        {% elif template_style == 'minimal' %}
          <div class="minimal-header">
            {% if brand_logo_url %}
              <img class="logo-img" src="{{ brand_logo_url }}" alt="{{ tenant_name }}" />
            {% else %}
              <span class="brand-name">{{ tenant_name }}</span>
            {% endif %}
          </div>

        {# -------- CLASSIC: accent bar + optional logo -------- #}
        {% else %}
          <div class="accent-bar"></div>
          {% if brand_logo_url %}
            <div class="logo-row">
              <img class="logo-img" src="{{ brand_logo_url }}" alt="{{ tenant_name }}" />
            </div>
          {% endif %}
        {% endif %}

        {# -------- Hero image (all styles) -------- #}
        {% if hero_gif_url or hero_image_url %}
          <div class="hero-img">
            <img src="{{ hero_gif_url or hero_image_url }}" alt="Rendering fotovoltaico" />
          </div>
        {% endif %}

        {# -------- Main content (child template fills this) -------- #}
        <div class="content">
          {% block content %}{% endblock %}

          {# ROI data box ---- #}
          {% if roi %}
            <div class="roi">
              <div class="roi-row">
                <span class="roi-label">Potenza installabile</span>
                <span class="roi-value">{{ roi.estimated_kwp }} kWp</span>
              </div>
              <div class="roi-row">
                <span class="roi-label">Risparmio annuo stimato</span>
                <span class="roi-value">€ {{ roi.yearly_savings_eur | format_money }}</span>
              </div>
              {% if roi.payback_years %}
                <div class="roi-row">
                  <span class="roi-label">Rientro stimato</span>
                  <span class="roi-value">~ {{ roi.payback_years }} anni</span>
                </div>
              {% endif %}
              {% if roi.co2_tonnes_25_years %}
                <div class="roi-row">
                  <span class="roi-label">CO₂ evitata (25 anni)</span>
                  <span class="roi-value">~ {{ roi.co2_tonnes_25_years }} t</span>
                </div>
              {% endif %}
            </div>
          {% endif %}

          {# CTA button ---- #}
          <p>
            <a class="cta" href="{{ lead_url }}">
              {{ cta_text or 'Vedi il tuo preventivo personalizzato' }}
            </a>
          </p>

          <p class="sign">
            Cordiali saluti,<br />
            Il team di {{ tenant_name }}
          </p>
        </div>

      </div>{# /card #}

      <div class="footer">
        {{ tenant_name }} — stima indicativa, non vincolante.<br />
        <a href="{{ optout_url }}">Non desidero più ricevere comunicazioni</a>
      </div>
    </div>
  </body>
</html>
