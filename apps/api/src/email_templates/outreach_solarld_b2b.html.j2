<!DOCTYPE html>
<html lang="it" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>{{ business_name | default(greeting_name, true) }} — analisi fotovoltaica</title>
  <!--[if mso]>
  <noscript><xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml></noscript>
  <![endif]-->
  <style type="text/css">
    body,table,td,a{-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;}
    table,td{mso-table-lspace:0;mso-table-rspace:0;}
    img{-ms-interpolation-mode:bicubic;border:0;outline:none;text-decoration:none;display:block;}
    body{margin:0!important;padding:0!important;width:100%!important;}
    a{text-decoration:none;}
    .ExternalClass{width:100%;}
    .ExternalClass,.ExternalClass p,.ExternalClass span,.ExternalClass td,.ExternalClass div{line-height:100%;}
    @media screen and (max-width:600px){
      .container{width:100%!important;border-radius:0!important;border-left:0!important;border-right:0!important;}
      .px{padding-left:18px!important;padding-right:18px!important;}
      .stack{display:block!important;width:100%!important;max-width:100%!important;box-sizing:border-box!important;padding-left:0!important;padding-right:0!important;}
      .hero-pad{padding-top:24px!important;padding-bottom:14px!important;}
      .h1{font-size:20px!important;line-height:26px!important;}
      .kwh{font-size:21px!important;line-height:27px!important;}
      .lead-p{font-size:15px!important;line-height:22px!important;}
      .mcard{padding:12px 12px!important;}
      .metric-num{font-size:19px!important;line-height:23px!important;}
      .metric-unit{font-size:12px!important;}
      .logo-img{height:46px!important;max-height:46px!important;}
      .h2-prop{font-size:17px!important;line-height:23px!important;}
      .cta-btn{display:block!important;width:100%!important;box-sizing:border-box!important;text-align:center!important;padding-left:0!important;padding-right:0!important;}
      .center-mb{text-align:center!important;}
    }
    @media (prefers-color-scheme:dark){
      .bg-page{background-color:#0b0d10!important;}
      .bg-card{background-color:#14171c!important;}
      .txt-dark{color:#e8eaed!important;}
      .txt-muted-d{color:#9aa0aa!important;}
      .border-d{border-color:#2a2e35!important;}
      .social{background-color:#14171c!important;}
    }
  </style>
</head>
{%- set accent = brand_color_accent | default('#22c55e', true) %}
{%- set navy = brand_primary_color | default('#0f1f3d', true) %}
<body class="bg-page" style="margin:0;padding:0;background-color:#f4f5f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

  {# Preheader nascosto #}
  <div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f4f5f7;opacity:0;">
    {%- if roi and roi.yearly_kwh %}Il vostro tetto{% if hq_province %} a {{ hq_province }}{% endif %} può produrre {{ roi.yearly_kwh | int | format_money }} kWh — €{{ (roi.yearly_savings_eur | int | format_money) if roi.yearly_savings_eur is defined else '' }} di risparmio stimato.{%- else %}Analisi fotovoltaica satellitare per {{ business_name | default('la vostra azienda', true) }}.{%- endif %}
    &#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;&#847;&zwnj;&nbsp;
  </div>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="bg-page" style="background-color:#f4f5f7;">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="container bg-card" style="width:600px;max-width:600px;background-color:#ffffff;border-radius:14px;overflow:hidden;border:1px solid #e8eaed;">

          {# HEADER — logo su bianco + accent line #}
          <tr>
            <td class="px" style="padding:20px 32px 0 32px;">
              {%- if brand_logo_url %}
              <img src="{{ brand_logo_url }}" width="95" height="52" alt="{{ tenant_name }}" class="logo-img" style="height:52px;width:auto;max-height:52px;">
              {%- else %}
              <span style="font-size:15px;font-weight:700;color:{{ navy }};">{{ tenant_name }}</span>
              {%- endif %}
            </td>
          </tr>
          <tr><td style="padding:14px 0 0 0;"><div style="height:3px;line-height:3px;font-size:0;background-color:{{ accent }};">&nbsp;</div></td></tr>

          {# HERO #}
          <tr>
            <td class="px hero-pad" style="padding:26px 32px 14px 32px;">
              <h1 class="h1 txt-dark" style="margin:0;font-size:22px;line-height:29px;font-weight:700;color:{{ navy }};letter-spacing:-0.3px;">
                {{ business_name | default(greeting_name, true) }}, il vostro tetto{% if hq_province %} a {{ hq_province }}{% endif %} può produrre<br>
                {%- if roi and roi.yearly_kwh %}
                <span class="kwh" style="font-size:23px;font-weight:700;color:{{ accent }};">{{ roi.yearly_kwh | int | format_money }} kWh all'anno</span>
                {%- else %}
                <span class="kwh" style="font-size:23px;font-weight:700;color:{{ accent }};">energia pulita dall'anno prossimo</span>
                {%- endif %}
              </h1>
              <p class="txt-muted-d lead-p" style="margin:12px 0 0 0;font-size:14px;line-height:21px;color:#4a4f57;">
                {{ copy_opening_line | default('Abbiamo analizzato la vostra sede via satellite. Qui sotto la sintesi; il report completo con simulazione, piano incentivi e ROI è nella vostra area personale.', true) }}
              </p>
            </td>
          </tr>

          {# IMMAGINE SATELLITARE (unica immagine di contenuto) #}
          {%- if hero_gif_url or hero_image_url %}
          <tr>
            <td class="px" style="padding:0 32px 8px 32px;">
              <img src="{{ hero_gif_url | default(hero_image_url, true) }}" width="536" alt="Vista satellitare della sede di {{ business_name | default(greeting_name, true) }} con simulazione pannelli fotovoltaici" style="width:100%;max-width:536px;height:auto;border-radius:8px;border:1px solid #e8eaed;">
              <p class="txt-muted-d" style="margin:8px 0 0 0;font-size:11px;line-height:16px;color:#9aa0aa;font-style:italic;text-align:center;">Simulazione fotorealistica — vista aerea della vostra sede</p>
            </td>
          </tr>
          {%- endif %}

          {# CARD EPC €0 #}
          {%- if epc_enabled %}
          <tr>
            <td class="px" style="padding:14px 32px 0 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:{{ navy }};border-radius:12px;">
                <tr>
                  <td style="padding:15px 20px;">
                    <p style="margin:0;font-size:10px;line-height:14px;color:{{ accent }};font-weight:700;letter-spacing:1px;text-transform:uppercase;">Modalità EPC · Formula chiavi in mano</p>
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-top:10px;"><tr>
                      <td style="vertical-align:middle;font-size:14px;line-height:20px;color:#dfe4ec;font-weight:600;padding-right:12px;">L'intero investimento è a carico nostro</td>
                      <td style="vertical-align:middle;text-align:right;width:1%;white-space:nowrap;">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="right"><tr>
                          <td style="background-color:{{ accent }};border-radius:9px;padding:9px 14px;text-align:center;">
                            <span style="display:block;font-size:9px;line-height:12px;color:{{ navy }};font-weight:700;letter-spacing:1px;text-transform:uppercase;">Voi investite</span>
                            <span style="display:block;font-size:24px;line-height:26px;color:{{ navy }};font-weight:700;">€0</span>
                          </td>
                        </tr></table>
                      </td>
                    </tr></table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          {%- endif %}

          {# DUE METRICHE #}
          {%- if roi and (roi.get('yearly_kwh') or roi.get('yearly_savings_eur')) %}
          <tr>
            <td class="px" style="padding:14px 32px 0 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
                {%- if roi.get('yearly_kwh') %}
                <td style="width:50%;vertical-align:top;padding-right:5px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="border-d" style="border:1px solid #e8eaed;border-radius:10px;"><tr><td class="mcard" style="padding:14px 16px;">
                    <p class="txt-muted-d" style="margin:0 0 5px 0;font-size:10px;line-height:13px;color:#8a9099;font-weight:600;letter-spacing:0.7px;text-transform:uppercase;">Producibilità annua</p>
                    <p class="metric-num txt-dark" style="margin:0;font-size:22px;line-height:26px;color:{{ navy }};font-weight:700;">{{ roi.yearly_kwh | int | format_money }} <span class="metric-unit" style="font-size:13px;color:#8a9099;font-weight:700;">kWh</span></p>
                  </td></tr></table>
                </td>
                {%- endif %}
                {%- if roi.get('yearly_savings_eur') %}
                <td style="width:50%;vertical-align:top;padding-left:5px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="border-d" style="border:1px solid #e8eaed;border-radius:10px;"><tr><td class="mcard" style="padding:14px 16px;">
                    <p class="txt-muted-d" style="margin:0 0 5px 0;font-size:10px;line-height:13px;color:#8a9099;font-weight:600;letter-spacing:0.7px;text-transform:uppercase;">Risparmio annuo in bolletta</p>
                    <p class="metric-num txt-dark" style="margin:0;font-size:22px;line-height:26px;color:{{ navy }};font-weight:700;">€{{ roi.yearly_savings_eur | int | format_money }}</p>
                  </td></tr></table>
                </td>
                {%- endif %}
              </tr></table>
            </td>
          </tr>
          {%- endif %}

          {# SOCIAL PROOF #}
          <tr>
            <td class="px" style="padding:16px 32px 0 32px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="social" style="background-color:#f5f7fa;border-radius:8px;"><tr>
                <td style="padding:12px 16px;font-size:12px;line-height:18px;color:#4a4f57;">
                  <span style="color:{{ accent }};font-weight:700;">&#10003;</span>&nbsp; {{ tenant_legal_name | default(tenant_name, true) }} · Installatore certificato GSE{% if installations_count | default(0, true) %} · <strong style="color:{{ navy }};">oltre {{ installations_count }} pratiche concluse</strong>{% if installations_area %} in {{ installations_area }}{% endif %}{% endif %}
                </td>
              </tr></table>
            </td>
          </tr>

          {# LAVORI REALIZZATI — 2 case study compatti (a rotazione) #}
          {%- if case_studies %}
          <tr>
            <td class="px" style="padding:22px 32px 0 32px;">
              <p class="txt-muted-d" style="margin:0 0 12px 0;font-size:10px;line-height:13px;color:#8a9099;font-weight:600;letter-spacing:0.7px;text-transform:uppercase;">Lavori realizzati</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr>
                {%- for cs in case_studies[:2] %}
                <td class="stack stack-mb" style="width:50%;vertical-align:top;padding-{{ 'right' if loop.first else 'left' }}:6px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="border-d" style="border:1px solid #e8eaed;border-radius:10px;overflow:hidden;">
                    {%- if cs.image_url %}
                    <tr><td style="font-size:0;line-height:0;"><img src="{{ cs.image_url }}" width="252" alt="Impianto realizzato{% if cs.client_name %} per {{ cs.client_name }}{% endif %}" style="width:100%;max-width:252px;height:96px;object-fit:cover;display:block;"></td></tr>
                    {%- endif %}
                    <tr><td style="padding:11px 13px;">
                      <p class="txt-dark" style="margin:0;font-size:13px;line-height:17px;color:{{ navy }};font-weight:700;">{{ cs.client_name }}</p>
                      <p class="txt-muted-d" style="margin:3px 0 0 0;font-size:11px;line-height:15px;color:#8a9099;">
                        {%- set bits = [] %}
                        {%- if cs.kwp %}{% set _ = bits.append((cs.kwp | round(1)) ~ ' kWp') %}{% endif %}
                        {%- if cs.location %}{% set _ = bits.append(cs.location) %}{% endif %}
                        {%- if cs.year %}{% set _ = bits.append(cs.year | string) %}{% endif %}
                        {{ bits | join(' · ') if bits else (cs.story or '') | truncate(60) }}
                      </p>
                    </td></tr>
                  </table>
                </td>
                {%- endfor %}
              </tr></table>
            </td>
          </tr>
          {%- endif %}

          {# PROPOSTA #}
          <tr>
            <td class="px" style="padding:24px 32px 0 32px;">
              <h2 class="txt-dark h2-prop" style="margin:0 0 6px 0;font-size:18px;line-height:24px;font-weight:700;color:{{ navy }};">La nostra proposta per voi</h2>
              <p class="txt-muted-d" style="margin:0 0 16px 0;font-size:14px;line-height:21px;color:#4a4f57;">Percorso completo dall'analisi alla realizzazione chiavi in mano:</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                {%- for item in [
                  ('Sopralluogo tecnico entro 7 giorni', 'per validare la stima satellitare e produrre il preventivo definitivo'),
                  ('Analisi incentivi 2026', '(Transizione 5.0, CER, autoconsumo) calibrata sulla vostra azienda'),
                  ('Pratica GSE gestita in meno di 30 giorni', 'dalla progettazione all\'allaccio')
                ] %}
                <tr>
                  <td width="26" valign="top" style="padding:0 0 12px 0;"><span style="display:inline-block;width:18px;height:18px;line-height:18px;text-align:center;border-radius:50%;border:1.5px solid {{ accent }};color:{{ accent }};font-size:11px;font-weight:700;">&#10003;</span></td>
                  <td valign="top" style="padding:0 0 12px 0;font-size:14px;line-height:21px;color:#4a4f57;"><strong style="color:{{ navy }};">{{ item[0] }}</strong> {{ item[1] }}</td>
                </tr>
                {%- endfor %}
              </table>
            </td>
          </tr>

          {# CTA UNICA (bulletproof) #}
          <tr>
            <td class="px center-mb" align="center" style="padding:26px 32px 6px 32px;">
              <!--[if mso]>
              <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ lead_url }}" style="height:48px;v-text-anchor:middle;width:340px;" arcsize="17%" strokecolor="{{ accent }}" fillcolor="{{ accent }}">
                <w:anchorlock/>
                <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">Vedi il report del vostro tetto &#8594;</center>
              </v:roundrect>
              <![endif]-->
              <!--[if !mso]><!-- -->
              <a href="{{ lead_url }}" target="_blank" class="cta-btn" style="display:inline-block;background-color:{{ accent }};color:#ffffff;font-size:16px;font-weight:700;line-height:16px;padding:16px 32px;border-radius:8px;mso-padding-alt:0;">Vedi il report del vostro tetto &#8594;</a>
              <!--<![endif]-->
            </td>
          </tr>
          <tr><td class="center-mb" align="center" style="padding:0 32px 4px 32px;"><p class="txt-muted-d" style="margin:0;font-size:11px;line-height:16px;color:#8a9099;">Accesso al report personale · Nessuna registrazione richiesta</p></td></tr>

          {# FIRMA — persona reale (referente) con foto/telefono/email.
             Fallback alla firma testuale del tenant se i campi referente
             non sono configurati. NB: si mostrano i contatti del MITTENTE
             (referente), mai l'email del destinatario. #}
          <tr>
            <td class="px" style="padding:22px 32px 26px 32px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="border-top:1px solid #eceef1;width:100%;">
                <tr><td colspan="2" style="height:18px;line-height:18px;font-size:0;">&nbsp;</td></tr>
                <tr>
                  {%- if referente_photo_url %}
                  <td width="60" valign="top" style="padding-right:12px;">
                    <img src="{{ referente_photo_url }}" width="48" height="48" alt="{{ referente_name | default(tenant_name, true) }}" style="width:48px;height:48px;border-radius:50%;">
                  </td>
                  {%- endif %}
                  <td valign="top" style="font-size:13px;line-height:19px;color:#4a4f57;">
                    A disposizione per qualsiasi domanda,<br>
                    {%- if referente_name %}
                    <strong style="color:{{ navy }};font-size:15px;">{{ referente_name }}</strong><br>
                    {%- if referente_role %}{{ referente_role }} · {% endif %}{{ tenant_name }}
                    {%- if referente_phone or referente_email %}<br>
                      {%- if referente_phone %}<a href="tel:{{ referente_phone }}" style="color:{{ accent }};font-weight:600;">{{ referente_phone }}</a>{% endif %}
                      {%- if referente_phone and referente_email %} · {% endif %}
                      {%- if referente_email %}<a href="mailto:{{ referente_email }}" style="color:{{ accent }};">{{ referente_email }}</a>{% endif %}
                    {%- endif %}
                    {%- else %}
                    <strong style="color:{{ navy }};font-size:15px;">{{ email_signature | default(sender_first_name | default(tenant_name, true), true) }}</strong>
                    {%- if not email_signature %}<br>{{ tenant_name }}{% endif %}
                    {%- endif %}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          {# FOOTER #}
          <tr>
            <td style="padding:18px 32px 22px 32px;background-color:#fafbfc;">
              <p style="margin:0 0 8px 0;font-size:11px;line-height:16px;color:#a3a8b0;"><strong style="color:#8a9099;">{{ tenant_legal_name | default(tenant_name, true) }}</strong>{% if tenant_vat_number %} · P.IVA {{ tenant_vat_number }}{% endif %}{% if tenant_legal_address %} · {{ tenant_legal_address }}{% endif %}</p>
              <p style="margin:0 0 8px 0;font-size:11px;line-height:16px;color:#a3a8b0;">Email inviata a {{ recipient_email | default('voi', true) }} per finalità di contatto commerciale B2B (art. 6.1.f GDPR — legittimo interesse). Indirizzo reperito da fonti pubbliche aziendali.</p>
              <p style="margin:0;font-size:11px;line-height:16px;color:#a3a8b0;"><a href="{{ optout_url }}" style="color:#a3a8b0;text-decoration:underline;">Disiscriviti</a></p>
            </td>
          </tr>

        </table>
        {%- if tracking_pixel_url %}<img src="{{ tracking_pixel_url }}" width="1" height="1" alt="" style="display:block;width:1px;height:1px;border:0;">{%- endif %}
      </td>
    </tr>
  </table>
</body>
</html>
