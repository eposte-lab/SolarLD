{
  "name": "solarlead",
  "version": "0.1.0",
  "private": true,
  "description": "SolarLead — Agentic Lead Generation Platform for Solar Installers",
  "author": "Alfonso Gallo",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:all": "cd infra && docker compose up -d redis && cd .. && concurrently -n api,worker,dashboard,portal -c blue,magenta,green,yellow \"pnpm --filter @solarlead/api dev\" \"cd apps/api && arq src.workers.main.WorkerSettings\" \"pnpm --filter @solarlead/dashboard dev\" \"pnpm --filter @solarlead/lead-portal dev\"",
    "dev:full-container": "cd infra && docker compose --profile app --profile local-db up",
    "lint": "turbo run lint",
    "check": "biome check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:start": "cd infra && docker compose up -d",
    "db:stop": "cd infra && docker compose down",
    "db:reset": "cd infra && docker compose down -v && docker compose up -d",
    "db:migrate": "pnpm --filter @solarlead/db migrate",
    "api:dev": "pnpm --filter @solarlead/api dev",
    "dashboard:dev": "pnpm --filter @solarlead/dashboard dev",
    "lead-portal:dev": "pnpm --filter @solarlead/lead-portal dev",
    "seed:demo": "cd apps/api && .venv/bin/python scripts/seed_demo_pipeline.py",
    "seed:demo:reset": "cd apps/api && .venv/bin/python scripts/seed_demo_pipeline.py --reset",
    "seed:demo:full": "cd apps/api && .venv/bin/python scripts/seed_demo_pipeline.py --reset --full-render"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.26.1"
}
