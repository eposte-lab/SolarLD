# ============================================================
# SolarLead — STAGING env template
# ============================================================
# DO NOT copy .env.example for staging — that file contains dev
# localhost defaults (JWT_SECRET placeholder, Redis on localhost,
# empty external keys). Staging must start with real, rotated
# secrets. The API's Settings validator refuses to start in
# APP_ENV=staging/production when any of the flagged values is
# still a dev default — see apps/api/src/core/config.py.
#
# Before deploying:
#   1. `grep -r REPLACE_ME .env.staging` must return NOTHING.
#   2. Every *_WEBHOOK_SECRET must be rotated and also configured
#      in the matching provider dashboard.
#
# Secret generation:
#   openssl rand -hex 32   # JWT_SECRET, ENCRYPTION_KEY
#   openssl rand -hex 24   # RESEND_INBOUND_SECRET (URL-safe enough)
# ============================================================

# ---- Runtime ----
NODE_ENV=production
APP_ENV=staging
DEBUG=false
LOG_LEVEL=INFO

# ---- Supabase (staging project) ----
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME_STAGING_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_ME_STAGING_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME_STAGING_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:REPLACE_ME@db.REPLACE_ME_STAGING_REF.supabase.co:5432/postgres
SUPABASE_JWT_SECRET=REPLACE_ME_STAGING_JWT_SECRET

# ---- API backend (Railway) ----
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=https://REPLACE_ME-api-staging.up.railway.app
NEXT_PUBLIC_API_URL=https://REPLACE_ME-api-staging.up.railway.app
CORS_ORIGINS=https://dashboard-staging.REPLACE_ME_DOMAIN,https://portal-staging.REPLACE_ME_DOMAIN

# ---- Frontends (Vercel) ----
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard-staging.REPLACE_ME_DOMAIN
NEXT_PUBLIC_LEAD_PORTAL_URL=https://portal-staging.REPLACE_ME_DOMAIN

# ---- Redis (Railway addon or Upstash) ----
# MUST NOT be localhost — the validator will refuse staging startup.
REDIS_URL=redis://default:REPLACE_ME@REPLACE_ME.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://REPLACE_ME.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_ME

# ---- AI ----
ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC
ANTHROPIC_MODEL=claude-sonnet-4-5
REPLICATE_API_TOKEN=REPLACE_ME_REPLICATE

# ---- Remotion sidecar (optional in staging) ----
VIDEO_RENDERER_URL=https://REPLACE_ME-video-staging.up.railway.app

# ---- Geo / Roof data ----
GOOGLE_SOLAR_API_KEY=REPLACE_ME_GOOGLE_SOLAR
GOOGLE_PLACES_API_KEY=REPLACE_ME_GOOGLE_PLACES
MAPBOX_ACCESS_TOKEN=REPLACE_ME_MAPBOX

# ---- Italian business data ----
VISURA_API_KEY=REPLACE_ME_VISURA
ATOKA_API_KEY=REPLACE_ME_ATOKA
HUNTER_API_KEY=REPLACE_ME_HUNTER
NEVERBOUNCE_API_KEY=REPLACE_ME_NEVERBOUNCE

# ---- Email (Resend) ----
RESEND_API_KEY=REPLACE_ME_RESEND_API
RESEND_WEBHOOK_SECRET=REPLACE_ME_RESEND_SVIX_SECRET
RESEND_INBOUND_SECRET=REPLACE_ME_RESEND_INBOUND_URL_SECRET

# ---- Postal (Pixart) ----
PIXART_API_KEY=REPLACE_ME_PIXART_API
PIXART_WEBHOOK_SECRET=REPLACE_ME_PIXART_WEBHOOK_SECRET

# ---- WhatsApp (360dialog) ----
DIALOG360_API_KEY=REPLACE_ME_DIALOG360_API
DIALOG360_WEBHOOK_SECRET=REPLACE_ME_DIALOG360_WEBHOOK_SECRET

# ---- Meta Marketing / Lead Ads (optional — leave blank until approved) ----
# META_APP_ID is what flips the integration on. If set, the validator
# forces both secret + verify_token to also be present.
# Per-tenant page access tokens + page webhook secrets live in
# `meta_connections` (Supabase), not here.
META_APP_ID=
META_APP_SECRET=
META_APP_VERIFY_TOKEN=

# ---- Payments (Stripe — not required for beta staging) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ---- Monitoring ----
SENTRY_DSN=REPLACE_ME_OR_LEAVE_EMPTY
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ---- Security ----
JWT_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32
ENCRYPTION_KEY=REPLACE_ME_WITH_openssl_rand_hex_32

# ============================================================
# Validation checklist (enforced by Settings._validate_non_dev_env_secrets):
# ============================================================
#  - APP_ENV                          must be "staging" or "production"
#  - JWT_SECRET                       ≥ 32 chars, not the dev default
#  - SUPABASE_SERVICE_ROLE_KEY        non-empty
#  - ANTHROPIC_API_KEY                non-empty
#  - RESEND_API_KEY                   non-empty
#  - RESEND_WEBHOOK_SECRET            non-empty (Svix HMAC for outbound events)
#  - RESEND_INBOUND_SECRET            non-empty (shared URL secret for replies)
#  - PIXART_WEBHOOK_SECRET            non-empty (HMAC for postal tracking)
#  - DIALOG360_WEBHOOK_SECRET         non-empty (HMAC for WhatsApp)
#  - REDIS_URL                        NOT redis://localhost or 127.0.0.1
# ============================================================
